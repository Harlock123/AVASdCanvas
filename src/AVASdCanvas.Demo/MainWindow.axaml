<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sd="clr-namespace:AVASdCanvas.Controls;assembly=AVASdCanvas"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="AVASdCanvas.Demo.MainWindow"
        Title="AVASdCanvas Demo" Width="900" Height="600">

    <DockPanel>
        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#2D2D30" Padding="8,4">
            <TextBlock x:Name="StatusText" Foreground="White" FontSize="12"
                       Text="Ready — hover or click on elements" />
        </Border>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#3C3C3C" Padding="8">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BtnAddEntity" Content="Add Entity" />
            <Button x:Name="BtnAddConnector" Content="Add Connector" />
            <Button x:Name="BtnClear" Content="Clear" />
            <Separator />
            <TextBlock Foreground="White" VerticalAlignment="Center" Text="Grid:" Margin="8,0,4,0" />
            <ToggleButton x:Name="BtnToggleGrid" IsChecked="True" Content="Visible" />
            <TextBlock Foreground="White" VerticalAlignment="Center" Text="Spacing:" Margin="8,0,4,0" />
            <NumericUpDown x:Name="SpacingInput" Value="20" Minimum="5" Maximum="100"
                           Increment="5" Width="100" />
            <TextBlock Foreground="White" VerticalAlignment="Center" Text="Snap:" Margin="8,0,4,0" />
            <ToggleButton x:Name="BtnToggleSnap" IsChecked="True" Content="On" />
        </StackPanel>
        </Border>

        <!-- Canvas -->
        <sd:SdCanvas x:Name="Canvas" />
    </DockPanel>
</Window>
